{
  "name": "pensive-unified",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run web:dev",
    "build": "npm run web:build",
    "convex:dev": "convex dev",
    "convex:deploy": "convex deploy",
    "convex:deployments": "convex deployments",
    "convex:codegen": "convex codegen",
    "convex:typecheck": "tsc -p convex/tsconfig.json",
    "web:dev": "vite --config \"Codebase - Pensive Web/config/vite.config.ts\"",
    "web:build": "tsc --noEmit -p \"Codebase - Pensive Web/config/tsconfig.app.json\" && tsc --noEmit -p \"Codebase - Pensive Web/config/tsconfig.node.json\" && vite build --config \"Codebase - Pensive Web/config/vite.config.ts\"",
    "web:preview": "vite preview --config \"Codebase - Pensive Web/config/vite.config.ts\"",
    "ios:test": "./scripts/test-ios-stable.sh",
    "lint": "eslint --config \"Codebase - Pensive Web/eslint.config.js\" \"Codebase - Pensive Web\"",
    "format": "prettier --ignore-path \"Codebase - Pensive Web/config/.prettierignore\" --cache --write \"Codebase - Pensive Web/**/*.{js,jsx,cjs,mjs,ts,tsx,cts,mts}\" \"convex/**/*.ts\"",
    "format:check": "prettier --ignore-path \"Codebase - Pensive Web/config/.prettierignore\" --check \"Codebase - Pensive Web/**/*.{js,jsx,cjs,mjs,ts,tsx,cts,mts}\" \"convex/**/*.ts\""
  },
  "prettier": {
    "plugins": [
      "./Codebase - Pensive Web/config/prettier-one-line-imports.mjs",
      "./Codebase - Pensive Web/config/prettier-one-line-props.mjs"
    ],
    "singleLineImports": true,
    "sortTopImportsByLength": true,
    "singleLineFunctionParamDestructuring": true,
    "overrides": [
      {
        "files": [
          "**/*.{js,jsx,cjs,mjs}"
        ],
        "options": {
          "parser": "imports-babel"
        }
      },
      {
        "files": [
          "**/*.{ts,tsx,cts,mts}"
        ],
        "options": {
          "parser": "imports-typescript"
        }
      }
    ]
  },
  "dependencies": {
    "@ark-ui/react": "^5.37.0",
    "@auth/core": "^0.37.0",
    "@convex-dev/auth": "^0.0.92",
    "@internationalized/date": "^3.12.2",
    "csv-parse": "^6.2.1",
    "lucide-react": "^1.14.0",
    "react": "^19.2.6",
    "react-aria-components": "^1.18.0",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "convex": "^1.39.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
